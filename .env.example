# HeatPump DB — environment variables (PLACEHOLDERS ONLY, never real values).
#
# Copy the pieces you need into a real env file:
#   .env                     — shared local values (gitignored)
#   .env.development.local   — LOCAL DEV ONLY; `vite build` does not read it,
#                              so anything here can never reach a deployed site.
# Anything prefixed VITE_ is compiled into the browser bundle and is therefore
# PUBLIC. Never give a secret (API key, webhook secret) a VITE_ prefix.

# ── Firebase (public by design) ───────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# App Check (reCAPTCHA Enterprise site key — public by design)
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-enterprise-site-key

# App Check debug token — LOCAL DEV ONLY (belongs in .env.development.local).
# reCAPTCHA cannot attest localhost, so dev exchanges a debug token instead.
# Leave unset and the app generates one, keeps it in localStorage and prints it
# to the console; register it once under
#   Firebase Console → App Check → Apps → <web app> → ⋮ → Manage debug tokens.
# Production ignores this entirely — App Check stays enforced there.
VITE_APPCHECK_DEBUG_TOKEN=your-registered-debug-token

# ── Market ────────────────────────────────────────────────────────────────────
# Which country edition this build serves: DE (default) | GB | FR
VITE_COUNTRY_CODE=DE

# ── Paddle Billing ────────────────────────────────────────────────────────────
# Client-side token for Paddle.js. Publishable by design — it is NOT an API key.
#   test_…  → Paddle SANDBOX      (belongs in .env.development.local)
#   live_…  → Paddle PRODUCTION   (only for a real production build)
# Unset ⇒ checkout stays disabled and every plan shows "coming soon".
# Price ids are NOT env vars — they live in src/config/paddlePrices.ts, keyed by
# currency, so every EUR market shares one catalogue.
VITE_PADDLE_CLIENT_TOKEN=test_your_sandbox_client_token

# ── Server-side only — NEVER prefix these with VITE_ ──────────────────────────
# GEMINI_API_KEY=...        # news pipeline (Cloud Function)
# SECRET_KEY=...            # manual trigger for the update function
# EPREL_API_KEY=...         # EPREL data fetch script
