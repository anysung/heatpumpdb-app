{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "target": "de",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "data/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "uk",
      "public": "dist-uk",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "data/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "fr",
      "public": "dist-fr",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "data/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "pl",
      "public": "dist-pl",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "data/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "hub",
      "public": "dist-admin",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "data/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ],
  "storage": [
    {
      "bucket": "heatpumpdb-datasets",
      "rules": "storage.rules"
    },
    {
      "bucket": "gen-lang-client-0324244302.firebasestorage.app",
      "rules": "storage.default.rules"
    }
  ]
}