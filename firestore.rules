rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Fetch the current authenticated user's Firestore profile.
    // Firestore caches the result within a single rule evaluation.
    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // A user is approved if:
    //   - status == 'active'  (normal approved user), OR
    //   - status field is absent AND isActive == true  (legacy users created before status field)
    // Any other status (pending, suspended, rejected, disabled, ...) is NOT approved.
    function isApproved() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (me().status == 'active' ||
              (!('status' in me()) && me().isActive == true));
    }

    // members[] and memberUids[] describe the same seats: the maps are what the
    // app renders, the uid list is what these rules can actually inspect. Any
    // write that leaves them out of step is rejected, so no code path — client,
    // script or future bug — can update one without the other.
    function membershipConsistent() {
      return request.resource.data.members.size() == request.resource.data.memberUids.size();
    }

    // The `orgId` pointer on a profile is what storage.rules follows to read the
    // team's entitlement, so it is not a harmless bookmark: pointing it at a
    // paid organization would BE the entitlement. Setting it therefore requires
    // already holding a seat there — the caller must appear in that org's
    // memberUids, which only the seat-claim path on the organizations document
    // can arrange (and that path proves the caller was invited).
    function seatedInOrg(orgId) {
      return orgId is string && orgId != '' &&
             exists(/databases/$(database)/documents/organizations/$(orgId)) &&
             request.auth.uid in
               get(/databases/$(database)/documents/organizations/$(orgId)).data.get('memberUids', []);
    }

    // True when the given organization has invited the caller's email. Used to
    // let an invited team member create their profile as an active member of
    // exactly that org (the seat was already bought by the team owner).
    function invitedToOrg(orgId) {
      return orgId is string && orgId != '' &&
             request.auth.token.email != null &&
             exists(/databases/$(database)/documents/organizations/$(orgId)) &&
             request.auth.token.email in
               get(/databases/$(database)/documents/organizations/$(orgId)).data.invitedEmails;
    }

    // Admin roles: owner, admin, support, ops
    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             me().get('role', 'user') in ['owner', 'admin', 'support', 'ops'];
    }

    // ── Users collection ──────────────────────────────────────────────────
    // - Any authenticated user may read their own doc (needed to check their own status at login).
    // - Registration (email or social) creates the user's own doc — allowed only
    //   as a non-privileged pending profile (the owner account is the exception).
    // - Users may update their own doc ONLY to request account deletion
    //   (store-required in-app deletion flow); everything else is admin-only.
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;

      allow create: if isSignedIn() && request.auth.uid == userId && (
        // Normal self-registration: pending, inactive, non-privileged.
        (request.resource.data.status == 'pending' &&
         request.resource.data.isActive == false &&
         request.resource.data.get('role', 'user') == 'user' &&
         // A self-registered account cannot hand itself paid entitlement.
         request.resource.data.get('paidAccess', false) == false) ||
        // Free-access grant registration: created directly active with the
        // granted plan (see grantRedemptionValid below).
        (grantRedemptionValid() &&
         request.resource.data.status == 'active' &&
         request.resource.data.get('role', 'user') == 'user') ||
        // Invited team member: the owner already paid for the seat and named
        // this email, so the profile may be created ACTIVE — but only as a
        // plain member of the org that actually invited them, and with no
        // subscription of its own (their access comes from the org).
        (invitedToOrg(request.resource.data.get('orgId', '')) &&
         request.resource.data.get('orgRole', '') == 'member' &&
         request.resource.data.status == 'active' &&
         request.resource.data.isActive == true &&
         request.resource.data.get('role', 'user') == 'user' &&
         !('subscription' in request.resource.data) &&
         // Their entitlement comes from the ORG at read time (storage.rules
         // follows orgId), never from a flag on their own profile — so the
         // profile must not carry one.
         request.resource.data.get('paidAccess', false) == false) ||
        // Owner bootstrap profile (matched by the authenticated email).
        request.auth.token.email == 'sungyongsoo1976@gmail.com'
      );

      allow update: if isSignedIn() && request.auth.uid == userId && (
        // Owner may maintain their own profile (e.g. role backfill for rules).
        request.auth.token.email == 'sungyongsoo1976@gmail.com' ||
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'isActive', 'deletionRequestedAt', 'deletionNote', 'lastActiveAt']) &&
          (
            // Self-service deletion request (Apple 5.1.1(v) / Google Play account deletion)
            request.resource.data.status == 'deletion_requested' ||
            // Heartbeat-only update
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastActiveAt'])
          )
        ) ||
        // Self-service profile edit (Account page). Name + company fields only —
        // status, role, plan, subscription and the org pointer stay out of reach.
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['firstName', 'lastName', 'companyName', 'companyType',
                      'companyTypeOther', 'companyCity', 'companyWebsite'])
        ) ||
        // Free-access grant redemption: an admin-issued grant for this email
        // may self-activate the account with exactly the granted plan/window.
        (
          grantRedemptionValid() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'isActive', 'subscription', 'billingChannel', 'paidAccess']) &&
          request.resource.data.status == 'active'
        ) ||
        // Team invite acceptance (join) and leaving a team. Membership itself is
        // validated on the organizations doc; here we only move the pointer.
        (
          // hasOnly already forbids touching paidAccess on this path, so joining
          // or leaving can never change an entitlement flag — no extra guard is
          // needed, and adding one would wrongly block a legitimate leave by
          // someone who holds their own subscription.
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['orgId', 'orgRole']) &&
          (
            // join — only into an org where the caller ALREADY holds a seat.
            // Without this check, pointing orgId at any paid team would grant
            // that team's catalogue access (storage.rules reads through it).
            (request.resource.data.get('orgRole', '') == 'member' &&
             seatedInOrg(request.resource.data.get('orgId', ''))) ||
            // leave — the client may delete the fields or null them out; the
            // access goes with the pointer, so nothing else needs clearing.
            (!('orgRole' in request.resource.data) ||
             request.resource.data.get('orgRole', '') == null)
          )
        )
      );

      allow read, write: if isAdmin();
    }

    // ── Subscription program ───────────────────────────────────────────────

    // Free-access grant for the caller's email (admin promotions).
    // Rules cannot parse ISO date strings, so the window is enforced by
    // binding the granted entitlement to the grant's own dates: a redeemed
    // subscription must copy planCode + endsAt from the grant doc, so an
    // expired grant can only ever yield an already-expired entitlement.
    function hasGrant() {
      return request.auth.token.email != null &&
             exists(/databases/$(database)/documents/freeAccessGrants/$(request.auth.token.email));
    }
    function grantData() {
      return get(/databases/$(database)/documents/freeAccessGrants/$(request.auth.token.email)).data;
    }
    function grantRedemptionValid() {
      return hasGrant() &&
             !('revokedAt' in grantData()) &&
             request.resource.data.subscription.provider == 'free_grant' &&
             request.resource.data.subscription.planCode == grantData().planCode &&
             request.resource.data.subscription.currentPeriodEndsAt == grantData().endsAt;
    }

    // Free-use registrations (email as doc id, lowercase). Admin writes;
    // the matching user may read + stamp redemption on their own grant.
    match /freeAccessGrants/{email} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.token.email == email);
      allow update: if isSignedIn() && request.auth.token.email == email &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['redeemedByUid', 'redeemedAt']) &&
        request.resource.data.redeemedByUid == request.auth.uid;
      allow read, write: if isAdmin();
    }

    // Team 3 / Team 5 organizations. Created by admin (or billing webhook —
    // Admin SDK bypasses rules). The owner manages seats but never the plan;
    // an invited user may claim a seat for themselves.
    //
    // READ is limited to people with a reason to see the doc: the owner, the
    // members, and an invited email. It used to be every signed-in account,
    // which exposed the full seat-email list of every customer team to any
    // logged-in user. The three clauses below preserve each real workflow —
    // getOrg/getMyOrg (owner + members), joinOrg and the
    // `invitedEmails array-contains` lookup in joinOrgIfInvited (invitee).
    match /organizations/{orgId} {
      allow read: if isAdmin() || (
        isSignedIn() && (
          request.auth.uid == resource.data.ownerUid ||
          request.auth.uid in resource.data.get('memberUids', []) ||
          (request.auth.token.email != null &&
           request.auth.token.email in resource.data.get('invitedEmails', []))
        )
      );
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        (
          // Owner: seats, invitations and the company profile the team inherits.
          // planCode / seatLimit / subscriptionStatus are absent from this list,
          // so the owner can never widen the team or grant themselves billing state.
          isSignedIn() && request.auth.uid == resource.data.ownerUid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['members', 'memberUids', 'invitedEmails', 'invitedAt', 'keepMemberUids',
                      'name', 'companyName', 'companyType', 'companyTypeOther',
                      'companyCity', 'companyWebsite']) &&
          // Seats: taken seats AND open invitations must fit the plan.
          request.resource.data.members.size()
            + request.resource.data.invitedEmails.size() <= resource.data.seatLimit &&
          membershipConsistent() &&
          // The owner can never drop their own seat (that would strand the team).
          resource.data.ownerUid in request.resource.data.memberUids
        ) ||
        (
          // Invited user claims their seat. memberUids proves the added seat is
          // the CALLER's own — rules cannot look inside the member maps.
          isSignedIn() && request.auth.token.email in resource.data.invitedEmails &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['members', 'memberUids', 'invitedEmails', 'invitedAt']) &&
          request.resource.data.members.size() <= resource.data.seatLimit &&
          request.resource.data.members.size() == resource.data.members.size() + 1 &&
          request.auth.uid in request.resource.data.memberUids &&
          membershipConsistent()
        ) ||
        (
          // Member leaves the team: exactly one seat goes, and it is their own —
          // they were in memberUids and are not any more.
          isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['members', 'memberUids', 'keepMemberUids']) &&
          request.auth.uid in resource.data.memberUids &&
          !(request.auth.uid in request.resource.data.memberUids) &&
          request.resource.data.members.size() == resource.data.members.size() - 1 &&
          membershipConsistent() &&
          request.auth.uid != resource.data.ownerUid
        );
    }

    // Renewal-time plan/term change requests (never applied mid-term).
    // Doc id == subscriber uid; user manages their own, admin sees all.
    match /subscriptionChangeRequests/{uid} {
      allow read, write: if isAdmin();
      allow read, create, update, delete: if isSignedIn() && request.auth.uid == uid;
    }

    // ── Billing webhook bookkeeping (server-owned) ────────────────────────
    // Both are written ONLY by the Paddle webhook through the Admin SDK, which
    // bypasses these rules — so no client write rule is granted at all, on
    // purpose. Admins read them from the Billing page.
    //   paddleWebhookEvents — processed event-id ledger (idempotency).
    //   billingQuarantine   — events we refused to act on (bad quantity,
    //                         unknown price id, unresolved account …).
    match /paddleWebhookEvents/{eventId} {
      allow read: if isAdmin();
    }
    match /billingQuarantine/{eventId} {
      allow read, update: if isAdmin();
    }

    // ── Support tickets (in-app inquiries ↔ admin inbox) ──────────────────
    // Users create tickets for themselves and read/update their own threads
    // (follow-up replies). Admins see and manage everything.
    match /supportTickets/{ticketId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read, write: if isAdmin();
    }

    // ── Activity logs ─────────────────────────────────────────────────────
    // Any authenticated user can append a log entry; only admins can read them.
    match /activityLogs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    // (printQuotas collection removed 2026-07-12 — data-sheet printing is
    //  unlimited for all members; tiering runs on the subscription program.)

    // ── Country data (news, policies, BAFA, metadata) ─────────────────────
    // Approved users and admins can read. Writes go through the Cloud Function
    // (Firebase Admin SDK), which bypasses these rules — but admin users
    // can also write from the UI if needed.
    match /countries/{countryCode} {
      allow read: if isApproved() || isAdmin();
      match /{subcollection}/{docId} {
        allow read: if isApproved() || isAdmin();
        allow write: if isAdmin();
      }
    }
  }
}
