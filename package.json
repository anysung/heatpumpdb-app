{
  "name": "heatpumpdb-app",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:de": "vite build",
    "build:uk": "VITE_COUNTRY_CODE=GB vite build --outDir dist-uk",
    "build:fr": "VITE_COUNTRY_CODE=FR vite build --outDir dist-fr",
    "build:admin": "VITE_APP_MODE=admin vite build --outDir dist-admin",
    "deploy:de": "npm run build:de && firebase deploy --only hosting:de",
    "deploy:uk": "npm run build:uk && firebase deploy --only hosting:uk",
    "deploy:fr": "npm run build:fr && firebase deploy --only hosting:fr",
    "deploy:admin": "npm run build:admin && firebase deploy --only hosting:hub",
    "preview": "vite preview",
    "test:registration": "bash tests/run-registration-e2e.sh",
    "start": "node server.js",
    "update:all": "node scripts/update-all.mjs",
    "update:all:deploy": "node scripts/update-all.mjs --fetch --fetch-eprel --deploy",
    "test:rules": "firebase emulators:exec --only firestore --project heatpumpdb-rules-test \"node tests/profile-team.rules.mjs\"",
    "test:signup": "bash tests/run-signup-account-e2e.sh",
    "test:segmentation": "node tests/segmentation.unit.mjs",
    "test:products": "bash tests/run-products-e2e.sh",
    "test": "npm run test:segmentation && npm run test:architecture && npm run test:matching && npm run test:rules && npm run test:products && npm run test:registration && npm run test:signup",
    "test:matching": "node tests/pel-matching.unit.mjs",
    "test:architecture": "node tests/architecture.unit.mjs"
  },
  "dependencies": {
    "@google/genai": "*",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "express": "^4.18.2",
    "firebase": "^10.7.1",
    "jspdf": "^4.2.1",
    "playwright": "^1.58.2",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17"
  }
}
