rules_version = '2';

// heatpumpdb-datasets bucket — the product catalogues (per-market JSON).
// Served ONLY to signed-in, admin-approved accounts via the Firebase SDK.
// This replaced public /data/*.json hosting files (anti-scraping, 2026-07-12):
// the datasets are the product; anonymous HTTP access is closed.
//
// Cross-service lookups require two one-time grants (done 2026-07-12):
//   service-<num>@firebase-rules.iam.gserviceaccount.com
//     → roles/firebaserules.firestoreServiceAgent  (project)
//   service-<num>@gcp-sa-firebasestorage.iam.gserviceaccount.com
//     → roles/storage.admin on gs://heatpumpdb-datasets (imported bucket)
service firebase.storage {
  match /b/{bucket}/o {

    // Same approval semantics as firestore.rules isApproved():
    // status == 'active', or legacy accounts with isActive == true.
    function me() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    function isApproved() {
      return request.auth != null &&
             firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
             (me().status == 'active' ||
              (!('status' in me()) && me().isActive == true));
    }
    function isAdmin() {
      return request.auth != null &&
             firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
             me().get('role', 'user') in ['owner', 'admin', 'support', 'ops'];
    }

    // The user's registered market (authService stamps country = ACTIVE_COUNTRY.code
    // on every signup). '' when the field is absent on a legacy doc.
    function myCountry() {
      return me().get('country', '');
    }

    match /datasets/{country}/{file} {
      // Per-market isolation (2026-07-19 audit follow-up): an approved user may
      // read ONLY their own registered market's datasets; owner/admin roles read
      // every market. A legacy doc with no 'country' field is NOT locked out — it
      // falls through to allowed, so a metadata gap can never deny a legitimate
      // approved user (new signups always carry country).
      allow read: if isAdmin() ||
                     (isApproved() && (myCountry() == '' || myCountry() == country));
      allow write: if false;  // uploads go through gcloud (pipeline), never clients
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
